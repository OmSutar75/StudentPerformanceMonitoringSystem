@model StudentPerformanceManagment.Models.ViewModel.IndividualRankViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Ranking - SPMS</title>
    <style>
        h1 {
            text-align: center;
            margin-bottom: 10px;
            font-size: 26px;
        }

        .subtitle {
            text-align: center;
            margin-bottom: 30px;
            font-size: 14px;
        }

        table {
            width: 85%;
            margin: auto;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #000;
            padding: 8px 12px;
            text-align: center;
            font-size: 14px;
        }

        th {
            background: #e6e6e6;
            font-weight: bold;
        }

        .topper {
            font-weight: bold;
            background: #f5f5f5;
        }

        .pass {
            color: #000;
        }

        .fail {
            color: #000;
        }

        footer {
            text-align: center;
            margin-top: 30px;
            font-size: 12px;
        }
    </style>
</head>
<body>

    <h1>Student Ranking Report</h1>
    <div class="subtitle">Student Performance Monitoring System</div>

    <table id="rankingTable">
        <thead>
            <tr>
                <th>Rank</th>
                <th>Name</th>
                <th>Theory</th>
                <th>Lab</th>
                <th>Internal</th>
                <th>Total</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
        <td>@Model.Rank</td>
        <td>@Model.Name</td>
        <td>@Model.Mark.TheoryMarks</td>
        <td>@Model.Mark.LabMarks</td>
        <td>@Model.Mark.InternalMarks</td>
        <td>@Model.Mark.TotalObtained</td>
        <td>@Model.Mark.ResultStatus</td>
        </tbody>
    </table>

    <footer>
        Generated by SPMS &mdash; Academic Use Only
    </footer>

    <script>
        const students = [
            { name: "Amit", theory: 35, lab: 38, internal: 18 },
            { name: "Sneha", theory: 40, lab: 39, internal: 20 },
            { name: "Rahul", theory: 30, lab: 28, internal: 15 },
            { name: "Priya", theory: 40, lab: 39, internal: 20 },
            { name: "Kiran", theory: 25, lab: 35, internal: 18 }
        ];

        function calculateStatus(s) {
            if (s.theory >= 16 && s.lab >= 16 && s.internal >= 8) return "Pass";
            return "Fail";
        }

        students.forEach(s => {
            s.total = s.theory + s.lab + s.internal;
            s.status = calculateStatus(s);
        });

        students.sort((a, b) => {
            if (b.total !== a.total) return b.total - a.total;
            return a.name.localeCompare(b.name);
        });

        const tbody = document.querySelector("#rankingTable tbody");

        students.forEach((s, index) => {
            const row = document.createElement("tr");
            if (index === 0) row.classList.add("topper");

            row.innerHTML = `
                <td>${index + 1}</td>
                <td>${s.name}</td>
                <td>${s.theory}</td>
                <td>${s.lab}</td>
                <td>${s.internal}</td>
                <td>${s.total}</td>
                <td>${s.status}</td>
            `;
            tbody.appendChild(row);
        });
    </script>

</body>
</html>
