<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f7f7f7;
            font-family: "Segoe UI", sans-serif;
        }

        .sidebar {
            width: 220px;
            min-height: 100vh;
            background: #e9e9e9;
            padding: 15px;
            position: fixed;
        }

        .menu-item {
            padding: 10px 12px;
            border-radius: 6px;
            margin-bottom: 8px;
            background: #fff;
            border: 1px solid #ccc;
            cursor: pointer;
        }

            .menu-item.active {
                background: #dcdcdc;
                font-weight: 600;
            }

        .topbar {
            height: 55px;
            background: #d9d9d9;
            padding: 10px 20px;
            margin-left: 220px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .content {
            margin-left: 220px;
            padding: 20px;
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    @Html.Partial("_LeftMenubar")

    <!-- TOPBAR -->
    @Html.Partial("_TopNavbar")

    <!-- MAIN CONTENT -->
    <div class="content">
        @Html.Partial("_StaffDashboard")
    </div>

</body>
</html>
