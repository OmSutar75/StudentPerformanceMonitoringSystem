@model StudentPerformanceManagment.Models.ViewModel.AddCourseGroupMV;

@{
    ViewData["Title"] = "Add Course Group";
    Layout = "_Layout";
}

<div class="container-fluid px-3 px-md-4">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
        <h4 class="fw-semibold text-primary mb-0">
            <i class="bi bi-journal-plus"></i> Add Course Group
        </h4>
        <a asp-action="CourseGroups" class="btn btn-outline-secondary btn-sm-md">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-3 p-md-4">
                    <form asp-action="AddCourseGroup" method="post">

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Course</label>
                            <select asp-for="CourseId" asp-items="Model.Courses" class="form-select form-select-lg-md">
                                <option value="">-- Select Course --</option>
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-12 col-sm-7">
                                <label class="form-label fw-semibold">Group Prefix</label>
                                <input name="GroupPrefix" class="form-control text-uppercase"
                                       placeholder="e.g. D" maxlength="1" required
                                       style="text-transform: uppercase;" />
                                <small class="text-muted d-block mt-1">Single letter according to Course</small>
                            </div>

                            <div class="col-12 col-sm-5">
                                <label class="form-label fw-semibold">Count</label>
                                <input name="GroupCount" type="number" class="form-control"
                                       min="1" max="6" value="1" required />
                                <small class="text-muted d-block mt-1">Max 6</small>
                            </div>
                        </div>

                        <div class="d-grid d-sm-flex justify-content-sm-end border-top pt-3">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm py-2 py-sm-2">
                                <i class="bi bi-magic"></i> Generate Groups
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}