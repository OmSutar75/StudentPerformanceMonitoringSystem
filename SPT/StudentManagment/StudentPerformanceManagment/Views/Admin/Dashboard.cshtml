@model StudentPerformanceManagment.Models.ViewModel.AllModelCount;

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f7f7f7;
            font-family: "Segoe UI", sans-serif;
        }

        .sidebar {
            width: 220px;
            min-height: 100vh;
            background: #e9e9e9;
            padding: 15px;
            position: fixed;
        }

        .menu-item {
            padding: 10px 12px;
            border-radius: 6px;
            margin-bottom: 8px;
            background: #fff;
            border: 1px solid #ccc;
            cursor: pointer;
        }

            .menu-item.active {
                background: #dcdcdc;
                font-weight: 600;
            }

        .topbar {
            height: 55px;
            background: #d9d9d9;
            padding: 10px 20px;
            margin-left: 220px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            text-align: right;
        }
        :root {
            --primary-color: #4361ee;
            --bg-body: #f8f9fa;
            --card-shadow: 0 4px 12px rgba(0, 0, 0, 0.05);
        }


        /* STAT CARDS */
        .stat-card {
            background: #fff;
            border: none;
            border-radius: 12px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            box-shadow: var(--card-shadow);
            transition: transform 0.2s ease;
        }

            .stat-card:hover {
                transform: translateY(-5px);
            }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
        }

        /* Icon Variations */
        .icon-blue {
            background: #e7f0ff;
        }

        .icon-green {
            background: #e2f7ed;
        }

        .icon-purple {
            background: #f3e8ff;
        }

        .icon-orange {
            background: #fff4e5;
        }

        .stat-details small {
            color: #6c757d;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 0.5px;
            font-weight: 600;
        }

        .stat-details h5 {
            margin: 0;
            font-weight: 700;
            color: #2d3436;
        }

        /* ACTIVITY LIST */
        .glass-card {
            background: #fff;
            padding: 20px;
            border-radius: 12px;
            box-shadow: var(--card-shadow);
            border: 1px solid rgba(0,0,0,0.02);
        }

        .activity-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .activity-list li {
                display: flex;
                gap: 15px;
                padding: 12px 0;
                border-bottom: 1px solid #f1f1f1;
            }

                .activity-list li:last-child {
                    border-bottom: none;
                }

        .activity-dot {
            width: 8px;
            height: 8px;
            background: var(--primary-color);
            border-radius: 50%;
            margin-top: 7px;
        }

        .activity-list p {
            margin: 0;
            font-size: 14px;
            color: #4a4a4a;
        }

        .time {
            display: block;
            font-size: 12px;
            color: #adb5bd;
        }

        /* TASK MINI STATS */
        .task-mini-stat {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            font-size: 14px;
            border-bottom: 1px dashed #eee;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }
    </style>
</head>

<body>

    <!-- MAIN CONTENT -->
    <div class="content">
       

        <div class="content">
            <header class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-bold mb-0">Admin Dashboard</h4>
                    <p class="text-muted">Welcome back, <span class="text-primary fw-semibold">@User.Identity.Name</span>!</p>
                </div>
                <div class="d-flex gap-2">
                    <a href="/Admin/EnrollStudent" class="btn btn-primary btn-sm px-3">＋ Add Student</a>
                    <a href="/Admin/AddStaff" class="btn btn-outline-primary btn-sm px-3">＋ Add Staff</a>
                </div>
            </header>

            <!-- TOP STAT CARDS -->
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-icon icon-blue">📘</div>
                        <div class="stat-details">
                            <small>Courses</small>
                            <h5>@Model.CourseCount</h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-icon icon-green">📗</div>
                        <div class="stat-details">
                            <small>Subjects</small>
                            <h5>@Model.SubjectCount</h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-icon icon-purple">🎓</div>
                        <div class="stat-details">
                            <small>Students</small>
                            <h5>@Model.StudentCount</h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-icon icon-orange">👨‍🏫</div>
                        <div class="stat-details">
                            <small>Staff</small>
                            <h5>@Model.StaffCount</h5>
                        </div>
                    </div>
                </div>
            </div>

            @* <div class="row g-4">
                <!-- RECENT ACTIVITIES -->
                <div class="col-lg-8">
                    <div class="glass-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold mb-0">RECENT ACTIVITIES</h6>
                            <span class="badge bg-light text-dark">View All</span>
                        </div>
                        <ul class="activity-list">
                            <li>
                                <div class="activity-dot"></div>
                                <p>Staff <b>STF001</b> submitted marks for MCA Sem-1 <span class="time">2h ago</span></p>
                            </li>
                            <li>
                                <div class="activity-dot"></div>
                                <p>New student enrolled: <b>PRN 202500010001</b> <span class="time">5h ago</span></p>
                            </li>
                            <li>
                                <div class="activity-dot"></div>
                                <p>Task deadline extended for Subject: <b>DBMS</b> <span class="time">Yesterday</span></p>
                            </li>
                            <li>
                                <div class="activity-dot"></div>
                                <p>Batch <b>MCA-2025</b> created successfully <span class="time">2 days ago</span></p>
                            </li>
                        </ul>
                    </div>
                </div> *@

                    <!-- TASK STATS -->
                    <div class="col-lg-4">
                        <div class="glass-card h-100">
                            <h6 class="fw-bold mb-3">TASK SUMMARY</h6>
                            <div class="task-mini-stat">
                                <span>Total Tasks</span>
                            <span class="fw-bold">@Model.TotalTasks</span>
                            </div>
                            <div class="task-mini-stat">
                                <span class="text-warning">● Pending</span>
                            <span class="fw-bold">@Model.PendingTasks</span>
                            </div>
                            <div class="task-mini-stat mb-3">
                                <span class="text-success">● Completed</span>
                                <span class="fw-bold">@Model.CompletedTasks</span>
                            </div>
                            <a href="/Admin/Tasks" class="btn btn-dark w-100 btn-sm">Assign New Task</a>
                        </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
